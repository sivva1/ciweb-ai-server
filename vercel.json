{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/hint",
      "dest": "/api/hint.py"
    },
    {
      "src": "/api/check",
      "dest": "/api/check.py"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    }
  ]
}
